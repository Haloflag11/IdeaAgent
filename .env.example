# =============================================================================
# IdeaAgent Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ── LLM Configuration ────────────────────────────────────────────────────────
# Your API key for the LLM provider (required)
OPENAI_API_KEY=your_openai_key

# Base URL for the LLM API endpoint
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name to use for completions
DEFAULT_MODEL=gpt-4o

# Maximum tokens in the response
MAX_TOKENS=65536

# Temperature for sampling (0.0 = deterministic, 1.0 = very random)
TEMPERATURE=0.7

# ── Agent Loop Configuration ─────────────────────────────────────────────────
# Maximum iterations the agent can perform in a single run
MAX_AGENT_ITERATIONS=20

# Maximum loop count before forcing termination (safety limit)
MAX_LOOP_COUNT=20

# Timeout for code execution in milliseconds
EXECUTION_TIMEOUT=50000

# ── Path Configuration ───────────────────────────────────────────────────────
# Root directory for sandbox workspaces (relative or absolute path)
WORKSPACE_ROOT=./sandbox_workspaces

# Directory for log files (relative or absolute path)
LOG_DIR=./logs

# Path to the SQLite database file
DB_PATH=~/.ideaagent/tasks.db

# ── MongoDB Configuration (Legacy - optional, only if using MongoDB) ─────────
# MongoDB connection URI (leave empty if using SQLite)
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name
MONGODB_DATABASE=IdeaAgent

# ── MCP Configuration (Optional) ─────────────────────────────────────────────
# Enable MCP integration (True/False)
MCP_ENABLED=False

# Path to MCP configuration file
MCP_CONFIG_PATH=mcp_config.json

# ── Logging Configuration ────────────────────────────────────────────────────
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file name
LOG_FILE=ideaagent.log
